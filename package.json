{
  "name": "piopiyjs",
  "title": "PIOPIY WebRTC JavaScript Browser SDK",
  "version": "0.14.0",
  "description": "Official PIOPIY WebRTC SDK for high-quality voice communication and telephony integration in the browser.",
  "main": "lib/index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "npm run lint && webpack --mode production",
    "ts-build": "tsc",
    "start": "webpack serve --mode development",
    "build-node": "babel src --out-dir lib --extensions .js",
    "start-node": "node lib/index.js",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telecmi/piopiy_client_js.git"
  },
  "keywords": [
    "piopiy",
    "webrtc",
    "voice",
    "telephony",
    "voip",
    "sip",
    "jssip",
    "telecmi",
    "sdk"
  ],
  "author": "TeleCMI",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/telecmi/piopiy_client_js/issues"
  },
  "homepage": "https://github.com/telecmi/piopiy_client_js#readme",
  "devDependencies": {
    "@babel/cli": "^7.27.0",
    "@babel/core": "^7.26.10",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-typescript": "^7.27.0",
    "@babel/register": "^7.25.9",
    "babel-cli": "^6.26.0",
    "babel-preset-env": "^1.7.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-watch": "^7.8.1",
    "eslint": "^9.39.4",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "webpack": "^5.99.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1"
  },
  "dependencies": {
    "jssip": "^3.13.6",
    "lodash-es": "^4.17.21",
    "socket.io-client": "^4.8.1",
    "underscore": "^1.13.7"
  }
}